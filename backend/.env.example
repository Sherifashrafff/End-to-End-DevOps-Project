# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Aurora PostgreSQL / local Postgres) ────────────────────────────
# Either set DATABASE_URL OR the individual vars below (DATABASE_URL takes precedence)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow_user
DB_PASSWORD=change_me
# SSL: set to "true" for Aurora in production (requires valid cert chain)
DB_SSL=false

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_random_64_char_string
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * only in development.
CORS_ORIGINS=http://localhost:8080

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Requests per window per IP (defaults applied in code if unset)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
